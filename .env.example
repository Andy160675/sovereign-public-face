# ---------------------------------------------------------------------------
# Sovereign Public Face — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# For Vercel deployment, set these in the Vercel Dashboard → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (REQUIRED for transactional emails)
RESEND_API_KEY="re_..."

# Database (REQUIRED)
DATABASE_URL="postgres://..."

# OAuth (auto-configured by Manus platform)
JWT_SECRET="..."
OAUTH_SERVER_URL="..."
OWNER_OPEN_ID="..."
VITE_APP_ID="codex-sovereign-systems"

# Runtime
NODE_ENV="production"
PORT="3000"

# Optional: Forge API (AI features)
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""
